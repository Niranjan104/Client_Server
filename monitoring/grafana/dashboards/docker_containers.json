            "datasource": "Prometheus",
            "targets": [
                {
                    "expr": "container_memory_usage_bytes",
                    "legendFormat": "{{id}}"
                }
            ],
            "gridPos": {
                "h": 9,
                "w": 12,
                "x": 12,
                "y": 0
            }
        },
        {
            "title": "Network Traffic Received",
